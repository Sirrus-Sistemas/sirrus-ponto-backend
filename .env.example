# ─── SERVIDOR ───────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── BANCO DE DADOS (MariaDB) ──────────────────────
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=passwordsirrus
DB_NAME=ponto_web
DB_CONNECTION_LIMIT=10

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=troque_por_uma_chave_segura_longa_aleatoria
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque_por_outra_chave_segura_diferente
JWT_REFRESH_EXPIRES_IN=7d

# ─── APP ────────────────────────────────────────────
TIMEZONE=America/Porto_Velho
TOLERANCIA_ATRASO_MIN=10
INTERVALO_MINIMO_MIN=60

# ─── SIRRUS PONTO MOBILE ────────────────────────────────
# URL base da API mobile PHP (sem barra final)
PONTOMOBILE_URL=
# CPF e senha do usuário admin criado na API mobile
PONTOMOBILE_CPF=
PONTOMOBILE_SENHA=

# ─── BANCO DE LICENÇAS (servidor remoto de liberações) ──────────────────
# Deixe em branco para desativar a verificação de licença (ex: ambiente de desenvolvimento)
LICENCA_DB_HOST=
LICENCA_DB_PORT=3306
LICENCA_DB_USER=
LICENCA_DB_PASSWORD=
LICENCA_DB_NAME=
# Valor do campo sistema_novo na tabela de licenças (inteiro ou string, conforme o banco remoto)
LICENCA_SISTEMA=2

# URL do frontend (link no e-mail de recuperação de senha; em dev o link também aparece nos logs)
FRONTEND_URL=http://localhost:5173
# Rota no front onde o usuário cola o token (query ?token=...)
PASSWORD_RESET_PATH=/redefinir-senha
